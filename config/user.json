{
  "version": "1.0",
  "description": "Default Joy-Con R to keyboard mapping",
  "deadzone": 0.2,
  "poll_interval": 0.01,
  "stick_mode": "4dir",
  "stick_enabled": true,
  "keep_alive_enabled": true,
  "mappings": {
    "buttons": {
      "DPadDown": {
        "action": "tap",
        "key": "enter"
      },
      "DPadRight": {
        "action": "tap",
        "key": "escape"
      },
      "DPadLeft": {
        "action": "tap",
        "key": "backspace"
      },
      "DPadUp": {
        "action": "sequence",
        "keys": [
          "alt",
          "tab"
        ],
        "repeat": 500
      },
      "L": {
        "action": "window_switch"
      },
      "ZL": {
        "action": "tap",
        "key": "+"
      },
      "Minus": {
        "action": "tap",
        "key": "+"
      },
      "Capture": {
        "action": "tap",
        "key": "print_screen"
      },
      "LStick": {
        "action": "tap",
        "key": "tab"
      },
      "SL": {
        "action": "hold",
        "key": "right alt"
      },
      "SR": {
        "action": "tap",
        "key": "-"
      }
    },
    "stick_directions": {
      "up": {
        "action": "auto",
        "key": "up",
        "repeat": 100
      },
      "down": {
        "action": "auto",
        "key": "down",
        "repeat": 100
      },
      "left": {
        "action": "auto",
        "key": "right",
        "repeat": 100
      },
      "right": {
        "action": "auto",
        "key": "left",
        "repeat": 100
      }
    }
  },
